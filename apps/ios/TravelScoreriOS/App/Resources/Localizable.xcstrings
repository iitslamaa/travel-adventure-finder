    "trip_planner.availability.trip_route_empty": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuge zuerst genaue Reisedaten hinzu und ordne dann jeden Tag einem Land zu oder markiere ihn als Reisetag."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add exact trip dates first, then assign each day to a country or mark it as travel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega primero las fechas exactas del viaje y luego asigna cada dia a un pais o marcalo como traslado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez d'abord des dates exactes au voyage, puis attribuez chaque jour a un pays ou marquez-le comme trajet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi prima le date esatte del viaggio, poi assegna ogni giorno a un paese o segnalo come giorno di viaggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione primeiro as datas exatas da viagem e depois associe cada dia a um pais ou marque-o como deslocamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала добавьте точные даты поездки, а затем распределите каждый день по стране или отметьте его как день дороги."
          }
        }
      }
    },
    "trip_planner.availability.trip_route_missing_dates": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuge oben zuerst Reisedaten hinzu, bevor du Tage Landern zuordnest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
