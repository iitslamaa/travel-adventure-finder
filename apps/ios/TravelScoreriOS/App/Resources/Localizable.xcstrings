    "country_detail.seasonality.body.shoulder": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Monat bietet eine gute Balance aus Wetter, Andrang und Preisen, mit einigen Abwagungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This month offers a decent balance of weather, crowds, and prices, with some trade-offs."
          }
        },
        "es": {
