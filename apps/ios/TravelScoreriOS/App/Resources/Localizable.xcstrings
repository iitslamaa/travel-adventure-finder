    "trip_planner.visa.overstay_warning_format": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ konnte den erlaubten visafreien Aufenthalt fur eine Reise von %lld Tagen überschreiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may exceed the allowed visa-free stay for a %lld-day trip."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ podria exceder la estancia permitida sin visa para un viaje de %lld dias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pourrait depasser la duree de sejour sans visa autorisee pour un voyage de %lld jours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ potrebbe superare il soggiorno senza visto consentito per un viaggio di %lld giorni."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pode ultrapassar a permanencia sem visto permitida para uma viagem de %lld dias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ может превысить разрешенный безвизовый срок для поездки на %lld дней."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ kan de toegestane visumvrije verblijfsduur voor een reis van %lld dagen overschrijden."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "قد يتجاوز %@ مدة الإقامة المسموح بها بدون تأشيرة لرحلة مدتها %lld يومًا."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ は %lld 日間の旅行に対して許可されているビザ免除滞在期間を超える可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@는 %lld일 여행에 대해 허용된 무비자 체류 기간을 초과할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ 可能会超过 %lld 天行程允许的免签停留时间。"
          }
        }
      }
    },
    "trip_planner.visa.overstay_warning_generic": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein oder mehrere Stopps könnten den erlaubten Aufenthalt fur diese Reise überschreiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One or more stops may exceed the allowed stay for this trip."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una o mas paradas podrian exceder la estancia permitida para este viaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une ou plusieurs etapes pourraient depasser la duree de sejour autorisee pour ce voyage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
