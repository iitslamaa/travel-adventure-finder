    "auth.sheet.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Melde dich an, um deine Bucket List zu speichern und auf allen Geraten zu synchronisieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to save your bucket list and sync across devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesion para guardar tu lista y sincronizarla entre dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous pour enregistrer votre bucket list et synchroniser vos appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedi per salvare la tua bucket list e sincronizzarla tra i dispositivi."
          }
        },
        "pt-BR": {
          "stringUnit": {
