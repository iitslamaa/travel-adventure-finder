    "trip_planner.visa.traveler_prep_summary_format": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may need visa prep for %@ %@. Best saved passport for that stop: %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ podria necesitar preparacion de visa para %@ %@. Mejor pasaporte guardado para esa parada: %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld voyageur(s) ont besoin d'une preparation visa avant le depart."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ konnten fur %@ %@ eine Visavorbereitung brauchen. Bester gespeicherter Pass fur diesen Stopp: %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ potrebbero aver bisogno di preparazione del visto per %@ %@. Miglior passaporto salvato per questa tappa: %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ podem precisar de preparacao de visto para %@ %@. Melhor passaporte salvo para essa parada: %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ может понадобиться визовая подготовка для %@ %@. Лучший сохраненный паспорт для этой остановки: %@."
          }
        }
      }
    },
    "trip_planner.whos_going.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep it solo or add friends to compare shared bucket-list countries."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenlo en solitario o agrega amigos para comparar paises compartidos de la lista de deseos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des amis ou gardez ce voyage en solo pour le moment."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass es solo oder füg Freunde hinzu, um gemeinsame Bucket-List-Lander zu vergleichen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienilo da solo oppure aggiungi amici per confrontare i paesi in comune nelle bucket list."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha solo ou adicione amigos para comparar paises compartilhados na lista de desejos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оставьте поездку сольной или добавьте друзей, чтобы сравнить общие страны из bucket list."
          }
        }
      }
    },
