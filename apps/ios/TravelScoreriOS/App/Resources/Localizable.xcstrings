    "profile.settings.delete_confirmation": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mochtest du dein Konto wirklich dauerhaft loschen? Dies kann nicht ruckgangig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to permanently delete your account? This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguro que quieres eliminar permanentemente tu cuenta? Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer votre compte de facon permanente ? Cette action est irreversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler eliminare definitivamente il tuo account? Questa azione non puo essere annullata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir sua conta permanentemente? Isso nao pode ser desfeito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить аккаунт?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weet je zeker dat je je account permanent wilt verwijderen? Dit kan niet ongedaan worden gemaakt."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "هل أنت متأكد أنك تريد حذف حسابك نهائيًا؟ لا يمكن التراجع عن هذا."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "本当にアカウントを永久に削除してもよろしいですか？これは元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "정말로 계정을 영구적으로 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您确定要永久删除您的账户吗？此操作无法撤销。"
          }
        }
      }
    },
