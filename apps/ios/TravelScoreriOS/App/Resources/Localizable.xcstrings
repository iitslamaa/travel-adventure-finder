    "trip_planner.availability.summary_empty_group": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sammelt freie Monate oder genaue Datumsbereiche, damit der Planer das beste gemeinsame Zeitfenster hervorheben kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start collecting free months or exact date ranges so the planner can spotlight the best shared window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza a reunir meses libres o rangos exactos para que el planificador destaque la mejor ventana compartida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez a collecter des mois libres ou des plages de dates exactes pour que le planificateur mette en avant la meilleure periode commune."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia a raccogliere mesi liberi o intervalli di date precisi cosi il planner potra evidenziare la finestra condivisa migliore."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece a reunir meses livres ou intervalos de datas exatos para que o planejador destaque a melhor janela em comum."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните собирать свободные месяцы или точные диапазоны дат, чтобы планировщик смог выделить лучшее общее окно."
          }
        }
      }
    },
    "trip_planner.availability.summary_empty_solo": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuge hier ein paar Datumsideen hinzu, damit deine Optionen sichtbar bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a couple of date ideas here to keep your planning options visible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega aqui un par de ideas de fechas para mantener visibles tus opciones de planificacion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez ici quelques idees de dates pour garder vos options visibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi qui qualche idea di data per mantenere visibili le tue opzioni."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione algumas ideias de datas aqui para manter suas opcoes visiveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте сюда пару идей по датам, чтобы ваши варианты планирования оставались на виду."
          }
        }
      }
    },
    "trip_planner.availability.summary_no_shared_window": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch kein gemeinsames Zeitfenster. Bitte alle, weitere freie Monate oder Datumsbereiche hinzuzufugen, damit der Planer eine bessere Uberschneidung findet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No shared window yet. Ask everyone to add a few more free months or date ranges so the planner can find a better match."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavia no hay una ventana compartida. Pidele a todos que agreguen algunos meses libres o rangos mas para que el planificador encuentre una mejor coincidencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de periode commune. Demandez a chacun d'ajouter plus de mois libres ou de plages de dates pour que le planificateur trouve une meilleure correspondance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessuna finestra condivisa. Chiedi a tutti di aggiungere altri mesi liberi o intervalli di date per trovare un incastro migliore."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda nao ha uma janela em comum. Peca para todos adicionarem mais meses livres ou intervalos de datas para que o planejador encontre uma combinacao melhor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общего окна пока нет. Попросите всех добавить еще несколько свободных месяцев или диапазонов дат, чтобы планировщик смог найти лучшее совпадение."
          }
        }
      }
    },
    "trip_planner.availability.swipe_months": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wische seitlich, um zwischen Monaten zu wechseln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe sideways to move across months."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza lateralmente para moverte entre meses."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez lateralement pour changer de mois."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
