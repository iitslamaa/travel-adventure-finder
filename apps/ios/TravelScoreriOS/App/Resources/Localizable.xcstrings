    "trip_planner.visa.traveler_prep_summary_format": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ konnten fur %@ %@ eine Visavorbereitung brauchen. Bester gespeicherter Pass fur diesen Stopp: %@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may need visa prep for %@ %@. Best saved passport for that stop: %@."
