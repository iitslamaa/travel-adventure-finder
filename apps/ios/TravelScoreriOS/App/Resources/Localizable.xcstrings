    "legal.general_information.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder provides informational travel insights only. All scores, advisories, and recommendations are intended for general guidance and educational purposes. Seasonality insights are based on historical climate averages and typical travel patterns."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder ofrece informacion de viaje solo con fines informativos. Todos los puntajes, avisos y recomendaciones son para orientacion general y fines educativos. La informacion de estacionalidad se basa en promedios climaticos historicos y patrones tipicos de viaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder fournit uniquement des informations et apercus de voyage. Tous les scores, alertes et recommandations sont proposes a titre indicatif et educatif. Les apercus de saisonnalite reposent sur des moyennes climatiques historiques et des habitudes de voyage typiques."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder bietet nur informative Reiseeinblicke. Alle Punktzahlen, Hinweise und Empfehlungen dienen der allgemeinen Orientierung und Bildungszwecken. Einblicke zur Saisonalitat basieren auf historischen Klimadurchschnitten und typischen Reisemustern."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder fornisce solo informazioni e indicazioni di viaggio. Tutti i punteggi, gli avvisi e le raccomandazioni sono destinati a orientamento generale e scopi educativi. Le indicazioni sulla stagionalita si basano su medie climatiche storiche e modelli di viaggio tipici."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Travel Adventure Finder fornece apenas informacoes e insights de viagem. Todas as pontuacoes, avisos e recomendacoes destinam-se a orientacao geral e fins educacionais. Os insights de sazonalidade se baseiam em medias climaticas historicas e padroes tipicos de viagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder предоставляет только информационные сведения о путешествиях. Все оценки, рекомендации и советы предназначены для общего ориентирования и образовательных целей. Сведения о сезонности основаны на исторических климатических средних и типичных туристических паттернах."
          }
        }
      }
    },
