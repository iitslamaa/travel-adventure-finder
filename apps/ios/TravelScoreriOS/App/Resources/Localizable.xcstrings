        }
      }
    },
    "country_detail.visa.body.visa_free": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst in der Regel ohne vorherige Visaorganisation einreisen, vorbehaltlich zeitlicher Begrenzungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can typically enter without arranging a visa in advance, subject to time limits."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Normalmente puedes entrar sin tramitar una visa por adelantado, sujeto a limites de tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez generalement entrer sans preparer de visa a l'avance, sous reserve de limites de duree."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Di solito puoi entrare senza organizzare un visto in anticipo, nel rispetto dei limiti di permanenza."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Normalmente voce pode entrar sem organizar um visto antecipadamente, sujeito aos limites de permanencia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычно можно въехать без визы заранее, с учётом ограничений по сроку пребывания."
          }
        }
      }
    },
    "country_detail.visa.body.visa_required": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst vor der Reise uber ein Konsulat oder einen offiziellen Kanal ein Visum erhalten."
