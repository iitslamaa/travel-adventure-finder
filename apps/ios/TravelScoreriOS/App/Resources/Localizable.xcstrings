    "trip_planner.expenses.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge, wer bezahlt hat, wer schuldet und was noch offen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track who paid, who owes, and what’s still outstanding."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lleva el control de quien pago, quien debe y que sigue pendiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez qui a paye, qui doit et ce qui reste en attente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni traccia di chi ha pagato, chi deve e cosa e ancora in sospeso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe quem pagou, quem deve e o que ainda esta pendente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отслеживайте, кто заплатил, кто должен и что еще осталось закрыть."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Houd bij wie betaald heeft, wie nog moet betalen en wat nog openstaat."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تتبع من دفع، ومن يدين، ومازال مستحقاً."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "誰が支払ったか、誰が借りているか、まだ未払いのものは何かを追跡します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "누가 지불했는지, 누가 빚이 있는지, 아직 남아 있는 금액이 무엇인지 추적하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "追踪谁已经付款、谁还欠款以及还有哪些未结清的款项。"
          }
        }
      }
    },
