    "country_detail.language.footer": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Basiert auf der landesweiten Sprachabdeckung und deinen gespeicherten Sprachcodes. Die Erfahrung vor Ort kann je nach Stadt und Region variieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on country-level language coverage and your saved language codes. Real-world experience can vary by city and region."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Basado en la cobertura de idiomas a nivel pais y tus codigos de idioma guardados. La experiencia real puede variar segun la ciudad y la region."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Base sur la couverture linguistique au niveau national et sur vos codes de langue enregistres. L'experience reelle peut varier selon la ville et la region."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Basato sulla copertura linguistica del paese e sui tuoi codici lingua salvati. L'esperienza reale puo variare da citta a regione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com base na cobertura linguistica do pais e nos seus codigos de idioma salvos. A experiencia real pode variar por cidade e regiao."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Основано на языковом покрытии страны и сохранённых вами языках. Реальный опыт может отличаться по городам и регионам."
          }
        }
      }
    },
