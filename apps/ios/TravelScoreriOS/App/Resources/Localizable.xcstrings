        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous devrez generalement faire la demande et payer en ligne avant le voyage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In der Regel musst du vor der Reise online beantragen und bezahlen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Di solito devi fare domanda e pagare online prima del viaggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
