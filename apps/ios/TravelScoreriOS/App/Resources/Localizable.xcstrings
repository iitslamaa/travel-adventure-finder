    "trip_planner.expenses.overlay_subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge, was bezahlt wurde, wer profitiert hat und wer noch schuldet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track what was paid, who benefited, and who still owes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lleva el control de lo pagado, quien se beneficio y quien todavia debe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez ce qui a ete paye, qui en a profite et qui doit encore."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni traccia di cosa e stato pagato, chi ne ha beneficiato e chi deve ancora pagare."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe o que foi pago, quem se beneficiou e quem ainda deve."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отслеживайте, что было оплачено, кто получил выгоду и кто все еще должен."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Houd bij wat is betaald, wie ervan heeft geprofiteerd en wie nog moet betalen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تتبع ما تم دفعه، ومن استفاد، ومن لا يزال مدينًا."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "支払われたもの、誰が利益を得たか、誰がまだ借りているかを追跡する。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "지불된 내역, 혜택을 받은 사람, 그리고 아직 빚을 진 사람을 추적하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
