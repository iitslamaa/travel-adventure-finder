        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Условия в целом благоприятны для этого месяца: хорошая погода и приемлемая загруженность."
          }
        }
      }
    },
    "country_detail.seasonality.body.poor": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Monat ist fur Wetter oder Andrang weniger ideal; wenn moglich, erwage andere Monate."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This month isn’t an ideal time for weather or crowds; consider different months if possible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes no es ideal por el clima o la afluencia; considera otros meses si es posible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mois n'est pas ideal pour la meteo ou l'affluence ; envisagez d'autres mois si possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
