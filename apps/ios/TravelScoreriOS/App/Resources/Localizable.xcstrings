    "trip_planner.availability.no_shared_window": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch kein gemeinsames Zeitfenster. Fuge in der Gruppe noch ein paar Ideen hinzu, damit der Planer bessere Uberschneidungen vorschlagen kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No shared window yet. Add a few more ideas across the group and the planner will suggest stronger matches here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavia no hay una ventana compartida. Agrega algunas ideas mas para el grupo y el planificador sugerira mejores coincidencias aqui."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de periode commune. Ajoutez quelques idees de plus dans le groupe et le planificateur proposera de meilleures correspondances ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non c'e ancora una finestra condivisa. Aggiungi ancora qualche idea nel gruppo e il planner suggerira opzioni migliori."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda nao ha uma janela em comum. Adicione mais opcoes no grupo e o planejador sugerira combinacoes melhores aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общего окна пока нет. Добавьте еще несколько идей по группе, и планировщик предложит здесь более сильные совпадения."
          }
        }
      }
    },
