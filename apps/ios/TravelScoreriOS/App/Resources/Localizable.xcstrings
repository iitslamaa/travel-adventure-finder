        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo territorio non ha una popolazione residente permanente, quindi non esiste un normale contesto linguistico locale da valutare."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este territorio nao tem populacao residente permanente, entao nao existe um ambiente linguistico tipico para avaliar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этой территории нет постоянного населения, поэтому обычную языковую среду здесь оценить нельзя."
          }
        }
      }
    },
