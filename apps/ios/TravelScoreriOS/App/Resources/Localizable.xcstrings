    "seasonality.view.shoulder_season_note": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Immer noch gute Bedingungen, oft mit weniger Andrang und besserem Preis-Leistungs-Verhaltnis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still good conditions, often fewer crowds and better value."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue habiendo buenas condiciones, a menudo con menos multitudes y mejor valor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Still good conditions, often fewer crowds and better value."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condizioni ancora buone, spesso con meno folla e un miglior rapporto qualita-prezzo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda com boas condicoes, muitas vezes com menos multidoes e melhor custo-beneficio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Условия все еще хорошие, часто меньше людей и лучше соотношение цены и качества."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nog steeds goede omstandigheden, vaak minder drukte en betere waarde."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لا تزال الظروف جيدة، غالبًا مع وجود حشود أقل وقيمة أفضل."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "まだ良いコンディションで、混雑も少なく、価値も高いことが多い。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "아직 좋은 상태이며, 종종 사람들이 적고 더 나은 가치를 제공합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "仍然是良好的条件，通常人群较少，性价比更高。"
          }
        }
      }
    },
