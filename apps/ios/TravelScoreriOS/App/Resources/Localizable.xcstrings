    "trip_planner.empty.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with one rough trip idea and refine it as dates, countries, and people come into focus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza con una idea general del viaje y refinála cuando las fechas, paises y personas se definan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par une idee approximative de voyage, puis affinez-la au fur et a mesure que les dates, les pays et les personnes se preciseront."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginne mit einer groben Reiseidee und verfeinere sie, wenn Daten, Lander und Mitreisende klarer werden."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia con un'idea di viaggio approssimativa e rifiniscila man mano che date, paesi e persone prendono forma."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece com uma ideia inicial de viagem e refine quando datas, paises e pessoas ficarem mais claras."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните с одной примерной идеи поездки и уточняйте ее по мере того, как проясняются даты, страны и люди."
          }
        }
      }
    },
