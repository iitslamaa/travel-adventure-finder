      "isCommentAutoGenerated": true
    },
    "%lld": {
      "comment": "A label inside the badge that shows the user's score. The content of the label is the integer representation of the user's score.",
      "isCommentAutoGenerated": true
    },
    "%lld%%": {
      "comment": "A small footnote indicating the weight of a score in the overall country score. The argument is the weight of the score as a percentage.",
      "isCommentAutoGenerated": true
    },
