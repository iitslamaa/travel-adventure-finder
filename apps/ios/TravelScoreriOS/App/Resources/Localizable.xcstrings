    "trip_planner.availability.edit_your_availability_subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update your submitted window without deleting it first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualiza tu ventana enviada sin eliminarla primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez a jour votre periode sans la supprimer d'abord."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisiere dein eingereichtes Zeitfenster, ohne es zuerst zu loschen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiorna la finestra inviata senza doverla eliminare prima."
          }
        },
        "pt-BR": {
