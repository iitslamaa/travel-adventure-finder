          "stringUnit": {
            "state": "translated",
            "value": "Normalmente voce pode entrar sem organizar um visto antecipadamente, sujeito aos limites de permanencia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычно можно въехать без визы заранее, с учётом ограничений по сроку пребывания."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "U kunt doorgaans binnenkomen zonder vooraf een visum te regelen, onder voorbehoud van tijdslimieten."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمكنك عادة الدخول دون ترتيب تأشيرة مسبقًا، مع مراعاة حدود الوقت."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "通常、事前にビザを手配しなくても入国できますが、滞在期間には制限があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "일정 기간 제한에 따라 일반적으로 비자를 미리 준비하지 않고 입국할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "通常情况下，你可以在没有事先办理签证的情况下入境，但有时间限制。"
          }
        }
      }
    },
    "country_detail.visa.body.visa_required": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst vor der Reise uber ein Konsulat oder einen offiziellen Kanal ein Visum erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You must secure a visa in advance through a consulate or official channel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Debes conseguir una visa con antelacion a traves de un consulado o un canal oficial."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous devez obtenir un visa a l'avance via un consulat ou un canal officiel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Devi ottenere un visto prima del viaggio tramite consolato o canale ufficiale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voce precisa garantir um visto antes da viagem por meio de um consulado ou canal oficial."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нужно заранее оформить визу через консульство или официальный канал."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "U moet van tevoren een visum verkrijgen via een consulaat of officiële kanaal."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يجب عليك الحصول على تأشيرة مسبقًا من خلال قنصلية أو قناة رسمية."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "領事館または公式の窓口を通じて、事前にビザを取得しなければなりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "비자는 반드시 영사관이나 공식 채널을 통해 사전에 확보해야 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "你必须通过领事馆或官方渠道提前获得签证。"
          }
        }
      }
    },
    "country_detail.visa.body.voa": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Visum wird bei Ankunft erteilt; rechne mit Papierkram und moglichen Gebuhren an der Grenze."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visa is issued on arrival; expect to handle paperwork and possible fees at the border."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La visa se emite a la llegada; espera realizar tramites y posibles pagos en la frontera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le visa est delivre a l'arrivee ; attendez-vous a gerer des formalites et d'eventuels frais a la frontiere."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il visto viene rilasciato all'arrivo; aspettati pratiche burocratiche e possibili costi alla frontiera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O visto e emitido na chegada; espere lidar com burocracia e possiveis taxas na fronteira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Виза оформляется по прибытии; будьте готовы к документам и возможным сборам на границе."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Visum wordt bij aankomst afgegeven; verwacht dat u papierenwerk en eventuele kosten bij de grens moet afhandelen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تُصدر التأشيرة عند الوصول؛ توقع التعامل مع الأوراق ورسوم محتملة على الحدود."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ビザは到着時に発行されます。国境で書類手続きを行い、場合によっては手数料がかかることがあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "비자는 도착 시 발급됩니다; 국경에서 서류 처리와 가능한 요금을 준비해야 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "签证在抵达时办理；预计需在边境处理相关文件和可能的费用。"
          }
        }
      }
    },
