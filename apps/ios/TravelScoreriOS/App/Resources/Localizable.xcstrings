        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige a que pais pertenece cada dia o marca el dia como traslado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez a quel pays appartient chaque jour, ou marquez le jour comme trajet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli a quale paese appartiene ogni giorno oppure segnalo come viaggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a qual pais cada dia pertence ou marque o dia como deslocamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, к какой стране относится каждый день, или отметьте день как день дороги."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kies bij welk land elke dag hoort, of markeer de dag als reis."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر أي دولة ينتمي إليها كل يوم، أو ضع علامة على اليوم كالسفر."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "各日がどの国に属するかを選ぶか、その日を旅行としてマークしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "각 날이 어느 나라에 속하는지 선택하거나, 그 날을 여행으로 표시하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择每天属于哪个国家，或将这一天标记为旅行日。"
          }
        }
      }
