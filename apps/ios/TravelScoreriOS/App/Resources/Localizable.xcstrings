    "country_detail.language.detail.tourism_heavy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It should be most useful in tourism-heavy areas rather than everywhere."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deberia ser mas util en zonas con mucho turismo que en todo el pais."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela sera surtout utile dans les zones tres touristiques plutot que partout."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am nutzlichsten ist es wahrscheinlich in stark touristischen Gegenden statt uberall."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Probabilmente sara piu utile nelle aree molto turistiche che ovunque."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Provavelmente sera mais util em areas fortemente turisticas do que em todo lugar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скорее всего, язык будет особенно полезен в туристических зонах, а не повсюду."
          }
        }
      }
    },
