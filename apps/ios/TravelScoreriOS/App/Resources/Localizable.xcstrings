    "legal.no_professional_advice.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder does not provide legal, medical, or governmental advice. Users should verify information with official sources before making travel decisions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder no ofrece asesoramiento legal, medico ni gubernamental. Los usuarios deben verificar la informacion con fuentes oficiales antes de tomar decisiones de viaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder ne fournit pas de conseils juridiques, medicaux ou gouvernementaux. Les utilisateurs doivent verifier les informations aupres de sources officielles avant de prendre des decisions de voyage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder bietet keine rechtliche, medizinische oder behordliche Beratung. Nutzer sollten Informationen vor Reiseentscheidungen bei offiziellen Quellen prufen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder non fornisce consulenza legale, medica o governativa. Gli utenti dovrebbero verificare le informazioni presso fonti ufficiali prima di prendere decisioni di viaggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Travel Adventure Finder nao fornece aconselhamento juridico, medico ou governamental. Os usuarios devem verificar as informacoes em fontes oficiais antes de tomar decisoes de viagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder не предоставляет юридических, медицинских или государственных консультаций. Перед принятием решений о поездке пользователям следует проверять информацию в официальных источниках."
          }
        }
      }
    },
