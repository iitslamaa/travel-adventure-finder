    "country_detail.language.empty.detail": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gebiet hat keine standige ansassige Bevolkerung, daher gibt es keine typische Sprachumgebung, mit der man vergleichen konnte."
          }
        },
        "en": {
