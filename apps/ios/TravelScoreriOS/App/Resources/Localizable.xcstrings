          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تحتاج هذه الرحلة إلى تواريخ مؤقتة قبل أن يمكن إضافتها إلى تقويم آبل."
          }
        },
        "ja": {
