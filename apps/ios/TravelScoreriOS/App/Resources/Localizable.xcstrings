    "friend_requests.empty.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn dir jemand eine Freundschaftsanfrage sendet, erscheint sie hier."
          }
        },
        "en": {
          "stringUnit": {
