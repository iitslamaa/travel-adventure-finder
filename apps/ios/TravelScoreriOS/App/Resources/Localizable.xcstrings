    "trip_planner.availability.your_availability_subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teile die Monate oder genauen Daten, die fur dich passen. Die Verfugbarkeit der anderen ist hier nur lesbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share the months or exact dates that work for you. Everyone else’s availability stays read-only here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte los meses o fechas exactas que te funcionan. La disponibilidad de los demas se mantiene solo de lectura aqui."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partagez les mois ou dates exactes qui vous conviennent. Les disponibilites des autres restent en lecture seule ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividi i mesi o le date esatte che vanno bene per te. La disponibilita degli altri qui e di sola lettura."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartilhe os meses ou datas exatas que funcionam para voce. A disponibilidade dos outros fica somente para leitura aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поделитесь месяцами или точными датами, которые вам подходят. Доступность остальных здесь остается только для чтения."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deel de maanden of exacte datums die voor jou werken. De beschikbaarheid van iedereen blijft hier alleen-lezen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "شارك الأشهر أو التواريخ الدقيقة التي تناسبك. تظل توفر كل شخص آخر للقراءة فقط هنا."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "あなたに都合の良い月や正確な日付を共有してください。他の人の空き状況はここでは閲覧専用のままです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "가능한 달이나 정확한 날짜를 공유하세요. 다른 사람들의 가능 여부는 여기서 읽기 전용으로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "分享适合你的月份或具体日期。其他人的可用时间在这里保持只读。"
          }
        }
      }
    },
    "trip_planner.basics.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib der Reise einen Namen und einen ungefahren Zeitraum, damit du mit der Planung beginnen kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give it a name and rough timing so you can start shaping it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponle un nombre y fechas aproximadas para empezar a darle forma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Donnez-lui un nom et une periode approximative pour commencer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dai un nome e un periodo approssimativo al viaggio per iniziare a costruirlo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dê um nome e um periodo aproximado para comecar a montar a viagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дайте поездке название и примерные сроки, чтобы начать ее формировать."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Geef het een naam en een ruwe tijdsindeling zodat je het kunt beginnen vorm te geven."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اعطه اسمًا وتوقيتًا تقريبيًا حتى تتمكن من البدء في تشكيله."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "名前と大まかな時間を付けて、形を作り始められるようにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "이름과 대략적인 시간을 정해서 그것을 구체화하기 시작하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "给它起个名字并大致安排时间，这样你就可以开始塑造它了。"
          }
        }
      }
    },
