          }
        }
      }
    },
    "country_detail.visa.body.freedom_of_movement": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This destination is part of a territory arrangement where %@ passport holders can move freely without visa limits."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este destino forma parte de un acuerdo territorial en el que los titulares del pasaporte %@ pueden moverse libremente sin limites de visa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette destination fait partie d'un accord territorial ou les titulaires d'un passeport %@ peuvent circuler librement sans limite de visa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Ziel ist Teil einer Gebietsregelung, in der Inhaber eines %@-Passes sich ohne Visabeschrankungen frei bewegen konnen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa destinazione fa parte di un accordo territoriale in cui i titolari di passaporto %@ possono muoversi liberamente senza limiti di visto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este destino faz parte de um arranjo territorial em que titulares de passaporte %@ podem circular livremente sem limites de visto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это направление входит в территориальное соглашение, по которому владельцы паспорта %@ могут свободно перемещаться без визовых ограничений."
          }
        }
      }
    },
