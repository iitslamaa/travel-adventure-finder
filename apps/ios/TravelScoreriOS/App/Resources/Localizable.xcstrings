    "discovery.preview.best_time_summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This month is one of the best times to visit based on weather, crowds, and overall conditions. Open the full country page to compare safety, affordability, and visa details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes es uno de los mejores momentos para visitar segun el clima, las multitudes y las condiciones generales. Abre la pagina completa del pais para comparar seguridad, asequibilidad y detalles de visa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mois-ci est l'un des meilleurs moments pour visiter selon la meteo, l'affluence et les conditions generales. Ouvrez la page complete du pays pour comparer securite, abordabilite et details de visa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Monat ist eine der besten Reisezeiten basierend auf Wetter, Andrang und allgemeinen Bedingungen. Offne die vollstandige Landesseite, um Sicherheit, Erschwinglichkeit und Visadetails zu vergleichen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo mese e uno dei momenti migliori per visitare in base a meteo, affollamento e condizioni generali. Apri la pagina completa del paese per confrontare sicurezza, convenienza e dettagli sul visto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes e um dos melhores para visitar com base no clima, nas multidoes e nas condicoes gerais. Abra a pagina completa do pais para comparar seguranca, custo e detalhes de visto."
          }
        },
        "ru": {
