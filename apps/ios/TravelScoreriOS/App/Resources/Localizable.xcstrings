    "trip_planner.availability.info_exact_vs_flexible": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use exact dates when someone already knows the week they’re free. Use flexible months when they only know the general timing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa fechas exactas cuando alguien ya sabe la semana en que estara libre. Usa meses flexibles cuando solo conoce el periodo general."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez des dates exactes quand quelqu'un connait deja la semaine ou il est libre. Utilisez des mois flexibles quand il ne connait que la periode generale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende genaue Daten, wenn jemand bereits weiss, in welcher Woche er frei hat. Nutze flexible Monate, wenn nur der grobe Zeitraum bekannt ist."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa date precise quando qualcuno sa gia in quale settimana e libero. Usa mesi flessibili quando conosce solo il periodo generale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use datas exatas quando alguem ja souber em que semana estara livre. Use meses flexiveis quando a pessoa so souber o periodo geral."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте точные даты, когда человек уже знает неделю, в которую он свободен. Используйте гибкие месяцы, когда известен только общий период."
          }
        }
      }
    },
