    "trip_planner.availability.summary_empty_group": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sammelt freie Monate oder genaue Datumsbereiche, damit der Planer das beste gemeinsame Zeitfenster hervorheben kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start collecting free months or exact date ranges so the planner can spotlight the best shared window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza a reunir meses libres o rangos exactos para que el planificador destaque la mejor ventana compartida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez a collecter des mois libres ou des plages de dates exactes pour que le planificateur mette en avant la meilleure periode commune."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia a raccogliere mesi liberi o intervalli di date precisi cosi il planner potra evidenziare la finestra condivisa migliore."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece a reunir meses livres ou intervalos de datas exatos para que o planejador destaque a melhor janela em comum."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните собирать свободные месяцы или точные диапазоны дат, чтобы планировщик смог выделить лучшее общее окно."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Begin met het verzamelen van gratis maanden of exacte datumbereiken zodat de planner het beste gedeelde venster kan uitlichten."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ابدأ في جمع الأشهر المجانية أو نطاقات التواريخ المحددة حتى يتمكن المخطط من تسليط الضوء على أفضل نافذة مشتركة."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "プランナーが最適な共有期間をハイライトできるように、無料の月や正確な日付範囲の収集を開始してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "무료 이용 달이나 정확한 날짜 범위를 모으기 시작하여 플래너가 가장 적합한 공유 기간을 강조 표시할 수 있도록 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "开始收集免费的月份或确切的日期范围，这样计划者就可以突出最佳的共享时间窗口。"
          }
        }
      }
    },
    "trip_planner.availability.summary_empty_solo": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuge hier ein paar Datumsideen hinzu, damit deine Optionen sichtbar bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a couple of date ideas here to keep your planning options visible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega aqui un par de ideas de fechas para mantener visibles tus opciones de planificacion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez ici quelques idees de dates pour garder vos options visibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
