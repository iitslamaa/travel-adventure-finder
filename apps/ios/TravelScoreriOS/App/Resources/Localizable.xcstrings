    "trip_planner.calendar_error_missing_dates": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Reise braucht vorlaufige Daten, bevor sie zu Apple Calendar hinzugefugt werden kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This trip needs tentative dates before it can be added to Apple Calendar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este viaje necesita fechas tentativas antes de poder agregarse a Apple Calendar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce voyage a besoin de dates provisoires avant d'etre ajoute a Apple Calendar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo viaggio ha bisogno di date provvisorie prima di poter essere aggiunto ad Apple Calendar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta viagem precisa de datas provisórias antes de poder ser adicionada ao Apple Calendar."
