    "discovery.weights.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your selected weights determine how Travelability Scores are calculated throughout the app. Rankings update after you save."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus pesos seleccionados determinan como se calculan los Travelability Scores en toda la app. Las clasificaciones se actualizan despues de guardar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les ponderations selectionnees determinent comment les Travelability Scores sont calcules dans l'application. Les classements se mettent a jour apres enregistrement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine ausgewahlten Gewichtungen bestimmen, wie Travelability Scores in der ganzen App berechnet werden. Die Ranglisten werden nach dem Speichern aktualisiert."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I pesi selezionati determinano come i Travelability Scores vengono calcolati nell'app. Le classifiche si aggiornano dopo il salvataggio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pesos selecionados determinam como as Travelability Scores sao calculadas em todo o aplicativo. As classificacoes sao atualizadas depois que voce salva."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте, как рассчитывается общий балл"
          }
        }
      }
    },
