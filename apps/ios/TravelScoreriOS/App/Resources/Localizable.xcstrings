          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras atuais podem limitar severamente ou proibir a entrada; confira orientacoes oficiais antes de planejar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущие правила могут серьёзно ограничивать или запрещать въезд; проверьте официальные рекомендации перед планированием."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Huidige regels kunnen de toegang ernstig beperken of verbieden; controleer de officiële richtlijnen voordat u plannen maakt."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "قد تحد القواعد الحالية بشكل كبير أو تمنع الدخول؛ تحقق من الإرشادات الرسمية قبل التخطيط."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "現在の規則により入国が大幅に制限されるか禁止される場合があります；計画を立てる前に公式の指示を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "현재 규정은 입국을 심하게 제한하거나 금지할 수 있으므로 계획을 세우기 전에 공식 지침을 확인하세요."
          }
        },
        "zh-Hans": {
