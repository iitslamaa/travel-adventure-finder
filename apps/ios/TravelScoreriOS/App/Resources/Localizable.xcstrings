    "seasonality.view.peak_season_note": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestes Wetter und beste Gesamtbedingungen - meist auch am vollsten und teuersten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Best weather and overall conditions — usually the busiest and priciest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejor clima y condiciones generales; normalmente la epoca mas concurrida y mas cara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Best weather and overall conditions — usually the busiest and priciest."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Meteo e condizioni migliori in assoluto, di solito anche il periodo piu affollato e costoso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Melhor clima e melhores condicoes gerais — normalmente o periodo mais cheio e caro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лучшая погода и общие условия, но обычно самый загруженный и дорогой период."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Beste weer en algehele omstandigheden — meestal het drukst en duurst."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أفضل الطقس والظروف بشكل عام — عادةً يكون الأكثر ازدحامًا والأغلى."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "最高の天気と全体的なコンディション — 通常、最も混雑していて価格も高いです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "최고의 날씨와 전반적인 조건 — 보통 가장 붐비고 가격이 비쌉니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "最佳的天气和整体条件——通常最繁忙且最昂贵。"
          }
        }
      }
    },
