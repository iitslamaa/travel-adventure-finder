    "trip_planner.visa.traveler_overstay_summary_format": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ könnte den erlaubten Aufenthalt in %@ %@ mit dem besten gespeicherten Pass (%@) überschreiten: etwa %lld Tag(e) erlaubt fur eine Reise von %lld Tagen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ may exceed the allowed stay in %@ %@ on their best saved passport (%@): about %lld day(s) allowed for a %lld-day trip."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ podria exceder la estancia permitida en %@ %@ con su mejor pasaporte guardado (%@): alrededor de %lld dia(s) permitidos para un viaje de %lld dias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld voyageur(s) pourraient depasser la duree de sejour autorisee."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ potrebbe superare il soggiorno consentito in %@ %@ con il miglior passaporto salvato (%@): circa %lld giorno(i) consentiti per un viaggio di %lld giorni."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pode ultrapassar a permanencia permitida em %@ %@ com seu melhor passaporte salvo (%@): cerca de %lld dia(s) permitidos para uma viagem de %lld dias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ может превысить разрешенный срок пребывания в %@ %@ по своему лучшему сохраненному паспорту (%@): разрешено около %lld дней для поездки длительностью %lld дней."
          }
        }
      }
    },
