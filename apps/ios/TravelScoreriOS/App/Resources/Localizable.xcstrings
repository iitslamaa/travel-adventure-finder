{
  "sourceLanguage": "en",
  "strings": {
    "": {
      "localizations": {}
    },
    " *": {
      "comment": "An asterisk that indicates a required field.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "—": {
      "comment": "A placeholder text used when a country's score is not yet available.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "@": {
      "comment": "An ampersand symbol used in the username field of the profile settings.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "@%@": {
      "comment": "A sublabel displaying a user's username.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "%@ %@": {
      "comment": "A text label displaying the country name and flag, followed by a text label showing the visa status. The first argument is the country name. The second argument is the country flag. The third argument is a description of the visa status.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$@"
          }
        }
      }
    },
    "%@: ": {
      "comment": "A label that describes a section of a view, such as \"Countries\" or \"Flags\".",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "%lld": {
      "comment": "A label inside the badge that shows the user's score. The content of the label is the integer representation of the user's score.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "%lld%%": {
      "comment": "A small footnote indicating the weight of a score in the overall country score. The argument is the weight of the score as a percentage.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "+%lld": {
      "localizations": {}
    },
    "🇯🇵 Tokyo": {
      "localizations": {}
    },
    "🇯🇵 TOKYO": {
      "comment": "A label displayed below a passport stamp, indicating the location of the stamp.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "✈︎": {
      "localizations": {}
    },
    "✉️": {
      "comment": "A symbol representing an envelope.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "🪣": {
      "comment": "An emoji used to represent an item that has been added to the user's bucket list.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "$": {
      "comment": "The dollar sign used in currency input fields.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
