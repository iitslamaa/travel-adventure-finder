    "trip_planner.availability.how_it_works_subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuge fur jeden Reisenden entweder genaue Zeitfenster oder flexible Monate hinzu und lass den Planer die starkste Uberschneidung finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add either exact windows or flexible months for each traveler, then let the planner surface the strongest overlap."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrega ventanas exactas o meses flexibles para cada viajero y deja que el planificador encuentre la mejor coincidencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez des dates exactes ou des mois flexibles pour chaque voyageur, puis laissez le planificateur afficher le meilleur chevauchement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi finestre precise o mesi flessibili per ogni viaggiatore e lascia che il planner trovi la sovrapposizione migliore."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione janelas exatas ou meses flexiveis para cada viajante e deixe o planejador mostrar a melhor sobreposicao."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте либо точные окна, либо гибкие месяцы для каждого путешественника, а планировщик покажет наилучшее пересечение."
          }
        }
      }
    },
