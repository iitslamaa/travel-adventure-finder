    "country_detail.language.empty.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This territory has no permanent settled population, so there is no typical resident language environment to score against."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este territorio no tiene una poblacion residente permanente, por lo que no existe un entorno linguistico tipico con el que comparar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
