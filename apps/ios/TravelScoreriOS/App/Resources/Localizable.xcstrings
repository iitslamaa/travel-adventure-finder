    "country_detail.seasonality.body.current": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Saisonalitatsdaten sind begrenzt; der Zeitpunkt kann trotzdem gut sein, aber prufe die lokalen Bedingungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seasonality data is limited; timing may still be fine, but check local conditions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de estacionalidad son limitados; aun asi podria ser un buen momento, pero revisa las condiciones locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les donnees de saisonnalite sont limitees ; la periode peut quand meme convenir, mais verifiez les conditions locales."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
