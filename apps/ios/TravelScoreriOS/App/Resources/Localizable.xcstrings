    "trip_planner.expenses.stats.empty": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Ausgaben erfasst. Fuge hier Hotels, Mahlzeiten, Tickets oder geteilte Kosten hinzu."
          }
        },
        "en": {
