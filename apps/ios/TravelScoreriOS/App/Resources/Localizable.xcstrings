    "country_detail.visa.body.varies": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einreiseregeln konnen von deinen Reisedetails abhangen; bestatige sie bei offiziellen Regierungsquellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Entry rules may depend on your trip details; confirm with official government sources."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas de entrada pueden depender de los detalles de tu viaje; confirmalo con fuentes oficiales del gobierno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les regles d'entree peuvent dependre des details de votre voyage ; confirmez-les aupres des sources officielles du gouvernement."
          }
        },
        "it": {
          "stringUnit": {
