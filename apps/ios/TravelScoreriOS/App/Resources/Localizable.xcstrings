    "country_detail.visa.body.ban": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current rules may severely limit or ban entry; check official guidance before planning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas actuales pueden limitar gravemente o prohibir la entrada; consulta la orientacion oficial antes de planificar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les regles actuelles peuvent fortement limiter ou interdire l'entree ; verifiez les recommandations officielles avant de planifier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuelle Regeln konnen die Einreise stark einschranken oder verbieten; prufe offizielle Hinweise vor der Planung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le regole attuali possono limitare severamente o vietare l'ingresso; controlla le indicazioni ufficiali prima di pianificare."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras atuais podem limitar severamente ou proibir a entrada; confira orientacoes oficiais antes de planejar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущие правила могут серьёзно ограничивать или запрещать въезд; проверьте официальные рекомендации перед планированием."
          }
        }
      }
    },
    "country_detail.visa.body.entry_permit": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You may need advance authorization or a permit before entry is approved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puede que necesites autorizacion previa o un permiso antes de que se apruebe la entrada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pourriez avoir besoin d'une autorisation prealable ou d'un permis avant que l'entree soit approuvee."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du brauchst moglicherweise vorab eine Genehmigung oder Erlaubnis, bevor die Einreise bewilligt wird."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Potrebbe essere necessaria un'autorizzazione preventiva o un permesso prima dell'approvazione dell'ingresso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Talvez voce precise de autorizacao previa ou de uma permissao antes da entrada ser aprovada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "До въезда может потребоваться предварительное разрешение или допуск."
          }
        }
      }
    },
    "country_detail.visa.body.evisa": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ll usually need to apply and pay online before travel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Normalmente tendras que solicitarla y pagar en linea antes de viajar."
          }
