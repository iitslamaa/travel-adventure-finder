    "trip_planner.no_friends_yet": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast noch keine Freunde hinzugefugt, daher bleibt diese Reise vorerst solo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You do not have any friends added yet, so this trip will stay solo for now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavia no tienes amigos agregados, asi que este viaje seguira siendo en solitario por ahora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas encore d'amis ajoutes, donc ce voyage restera solo pour le moment."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non hai ancora aggiunto amici, quindi questo viaggio restera per ora in solitaria."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voce ainda nao adicionou nenhum amigo, entao esta viagem vai continuar solo por enquanto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас пока нет добавленных друзей, поэтому эта поездка пока останется сольной."
          }
        },
        "nl": {
          "stringUnit": {
