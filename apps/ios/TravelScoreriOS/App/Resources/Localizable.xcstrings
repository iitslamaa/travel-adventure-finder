    "profile.settings.passports.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Private to you. Used to personalize visa rules and passport recommendations with your strongest saved passport for each destination."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Privado para ti. Se usa para personalizar reglas de visa y recomendaciones de pasaporte con tu pasaporte guardado mas fuerte para cada destino."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prive pour vous. Utilise pour personnaliser les regles de visa et les recommandations de passeport avec votre meilleur passeport enregistre pour chaque destination."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur fur dich sichtbar. Wird verwendet, um Visaregeln und Passempfehlungen mit deinem starksten gespeicherten Pass fur jedes Ziel zu personalisieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Privato per te. Serve a personalizzare regole sui visti e consigli sui passaporti con il tuo passaporto salvato migliore per ogni destinazione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Privado para voce. Usado para personalizar regras de visto e recomendacoes de passaporte com seu melhor passaporte salvo para cada destino."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только для вас. Используются для персонализации визовых правил и рекомендаций по паспортам на основе вашего самого сильного сохраненного паспорта для каждого направления."
          }
        }
      }
    },
