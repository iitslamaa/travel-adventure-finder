        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "До въезда может потребоваться предварительное разрешение или допуск."
          }
        }
      }
    },
    "country_detail.visa.body.evisa": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In der Regel musst du vor der Reise online beantragen und bezahlen."
          }
