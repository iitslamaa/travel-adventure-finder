    "trip_planner.itinerary.day_by_day_subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wahle fur jeden Tag das Land aus oder markiere einen Tag als Reisetag, damit die Kosten die tatsachliche Route widerspiegeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the country for each day, or mark a day as travel so trip costs reflect your actual routing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el pais para cada dia o marca un dia como traslado para que los costos reflejen tu ruta real."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez le pays pour chaque jour, ou marquez un jour comme trajet pour que les couts du voyage refletent votre vrai parcours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli il paese per ogni giorno oppure segna un giorno come viaggio, cosi i costi riflettono il percorso reale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o pais para cada dia ou marque um dia como deslocamento para que os custos reflitam sua rota real."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите страну для каждого дня или отметьте день как дорогу, чтобы расходы на поездку отражали ваш реальный маршрут."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kies het land voor elke dag, of markeer een dag als reisdag zodat de reiskosten uw werkelijke route weerspiegelen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر البلد لكل يوم، أو ضع علامة على يوم كرحلة حتى تعكس تكاليف الرحلة مسارك الفعلي."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "各日の国を選ぶか、または1日を移動日としてマークして、旅行費用が実際のルートを反映するようにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "각 날짜마다 국가를 선택하거나 여행일로 표시하여 실제 경로에 맞게 여행 비용을 반영하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "为每一天选择国家，或者将某一天标记为旅行，以便旅行费用反映您的实际路线。"
          }
        }
      }
    },
