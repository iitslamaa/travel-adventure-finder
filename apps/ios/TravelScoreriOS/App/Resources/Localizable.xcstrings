          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione algumas ideias de datas aqui para manter suas opcoes visiveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте сюда пару идей по датам, чтобы ваши варианты планирования оставались на виду."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Voeg hier een paar date-ideeën toe om je planningsopties zichtbaar te houden."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أضف بعض أفكار المواعدة هنا للحفاظ على خيارات التخطيط الخاصة بك مرئية."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ここにいくつかのデートのアイデアを追加して、計画のオプションを見えるようにしておきましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "계획 옵션을 쉽게 볼 수 있도록 여기에 데이트 아이디어 몇 가지를 추가하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在这里添加几个约会点子，以保持你的计划选项可见。"
          }
        }
      }
    },
    "trip_planner.availability.summary_no_shared_window": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch kein gemeinsames Zeitfenster. Bitte alle, weitere freie Monate oder Datumsbereiche hinzuzufugen, damit der Planer eine bessere Uberschneidung findet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No shared window yet. Ask everyone to add a few more free months or date ranges so the planner can find a better match."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavia no hay una ventana compartida. Pidele a todos que agreguen algunos meses libres o rangos mas para que el planificador encuentre una mejor coincidencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de periode commune. Demandez a chacun d'ajouter plus de mois libres ou de plages de dates pour que le planificateur trouve une meilleure correspondance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessuna finestra condivisa. Chiedi a tutti di aggiungere altri mesi liberi o intervalli di date per trovare un incastro migliore."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda nao ha uma janela em comum. Peca para todos adicionarem mais meses livres ou intervalos de datas para que o planejador encontre uma combinacao melhor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общего окна пока нет. Попросите всех добавить еще несколько свободных месяцев или диапазонов дат, чтобы планировщик смог найти лучшее совпадение."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nog geen gedeeld venster. Vraag iedereen om een paar extra vrije maanden of datumbereiken toe te voegen zodat de planner een betere match kan vinden."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لا توجد نافذة مشتركة بعد. اطلب من الجميع إضافة بضعة أشهر أو نطاقات تواريخ مجانية حتى يتمكن المخطط من العثور على تطابق أفضل."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "まだ共有されている時間枠はありません。プランナーがより良いマッチを見つけられるように、皆にもう少し自由な月や日付範囲を追加するように頼んでください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "아직 공유된 일정이 없습니다. 계획자가 더 나은 일정을 찾을 수 있도록 모두에게 몇 달 또는 날짜 범위를 더 추가하도록 요청하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "还没有共享的时间窗口。请大家添加几个月或几段日期的空闲时间，这样日程安排者才能找到更合适的匹配。"
          }
        }
      }
    },
