    "country_detail.seasonality.body.best": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wetter und Andrang sind fur diesen Monat ideal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather and crowd patterns are ideal for this month."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clima y los patrones de afluencia son ideales para este mes."
          }
        },
