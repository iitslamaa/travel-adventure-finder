    "legal.limitation_of_liability.body": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder ist nicht verantwortlich fur Entscheidungen, die auf den in der App dargestellten Informationen basieren. Die Nutzung dieser App erfolgt nach eigenem Ermessen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder is not responsible for decisions made based on information presented in the app. Use of this app is at your own discretion."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder no es responsable por decisiones tomadas con base en la informacion presentada en la app. El uso de esta app queda a tu discrecion."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder n'est pas responsable des decisions prises a partir des informations presentees dans l'application. Vous utilisez cette application a votre discretion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder non e responsabile delle decisioni prese sulla base delle informazioni presentate nell'app. L'uso dell'app e a tua discrezione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Travel Adventure Finder nao se responsabiliza por decisoes tomadas com base nas informacoes apresentadas no aplicativo. O uso deste app e por sua propria conta e criterio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Travel Adventure Finder не несет ответственности за решения, принятые на основе информации, представленной в приложении. Вы используете это приложение по своему усмотрению."
          }
        }
      }
    },
