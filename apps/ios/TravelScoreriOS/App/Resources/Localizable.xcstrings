    "country_detail.seasonality.body.best": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wetter und Andrang sind fur diesen Monat ideal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather and crowd patterns are ideal for this month."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clima y los patrones de afluencia son ideales para este mes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La meteo et l'affluence sont ideales pour ce mois."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Meteo e affluenza sono ideali per questo mese."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clima e padroes de movimento sao ideais para este mes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Погодные условия и уровень загруженности идеальны для этого месяца."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Het weer en de druktepattensen zijn ideaal voor deze maand."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الطقس وأنماط الحشود مثالية لهذا الشهر."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "天気と人出のパターンは今月に最適です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "이번 달의 날씨와 사람들의 패턴은 이상적입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "这个月的天气和人群模式都很理想。"
          }
        }
      }
    },
    "country_detail.seasonality.body.current": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Saisonalitatsdaten sind begrenzt; der Zeitpunkt kann trotzdem gut sein, aber prufe die lokalen Bedingungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seasonality data is limited; timing may still be fine, but check local conditions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de estacionalidad son limitados; aun asi podria ser un buen momento, pero revisa las condiciones locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les donnees de saisonnalite sont limitees ; la periode peut quand meme convenir, mais verifiez les conditions locales."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati sulla stagionalita sono limitati; il periodo potrebbe comunque andare bene, ma controlla le condizioni locali."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados de sazonalidade sao limitados; o momento ainda pode ser bom, mas confira as condicoes locais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Данные по сезонности ограничены; время всё ещё может быть удачным, но проверьте местные условия."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Seizoensgebonden gegevens zijn beperkt; de timing kan nog steeds goed zijn, maar controleer de lokale omstandigheden."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "بيانات الموسمية محدودة؛ قد يكون التوقيت لا يزال مناسبًا، لكن تحقق من الظروف المحلية."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "季節性のデータは限られています；時期はまだ適しているかもしれませんが、現地の状況を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "계절별 데이터가 제한적입니다; 시기는 여전히 적절할 수 있지만 지역 상황을 확인하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "季节性数据有限；时机可能仍然合适，但请检查当地情况。"
          }
        }
      }
    },
    "country_detail.seasonality.body.good": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Bedingungen sind in diesem Monat allgemein gunstig, mit ordentlichem Wetter und Andrang."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conditions are generally favorable for this month, with decent weather and crowds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las condiciones suelen ser favorables este mes, con buen clima y una afluencia razonable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conditions sont globalement favorables pour ce mois, avec une bonne meteo et une affluence raisonnable."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le condizioni sono generalmente favorevoli in questo mese, con buon meteo e affluenza gestibile."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As condicoes geralmente sao favoraveis neste mes, com clima e movimento razoaveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Условия в целом благоприятны для этого месяца: хорошая погода и приемлемая загруженность."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "De omstandigheden zijn over het algemeen gunstig voor deze maand, met redelijk weer en drukte."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الظروف بشكل عام مهيأة لهذا الشهر، مع طقس جيد وحشود."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "今月の天候はおおむね良好で、天気や人出もまずまずです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "이번 달의 조건은 일반적으로 좋으며, 날씨와 사람들도 적절합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "本月的条件总体上是有利的，天气和人群都不错。"
          }
        }
      }
    },
    "country_detail.seasonality.body.poor": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Monat ist fur Wetter oder Andrang weniger ideal; wenn moglich, erwage andere Monate."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This month isn’t an ideal time for weather or crowds; consider different months if possible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes no es ideal por el clima o la afluencia; considera otros meses si es posible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mois n'est pas ideal pour la meteo ou l'affluence ; envisagez d'autres mois si possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo mese non e ideale per meteo o affluenza; se possibile valuta altri mesi."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes nao e o ideal para clima ou movimento; se possivel, considere outros meses."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот месяц не лучший по погоде и загруженности; если возможно, рассмотрите другие месяцы."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deze maand is niet ideaal qua weer of drukte; overweeg andere maanden indien mogelijk."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ليس هذا الشهر وقتًا مثاليًا للطقس أو للزحام؛ فكر في أشهر مختلفة إذا أمكن."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "今月は天気や混雑の面で理想的な時期ではありません；可能であれば別の月を検討してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "이번 달은 날씨나 사람들로 인해 이상적인 시기가 아닙니다; 가능하다면 다른 달을 고려하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "这个月份的天气和人群都不是理想的时间；如果可能的话，考虑其他月份。"
          }
        }
      }
    },
    "country_detail.seasonality.body.shoulder": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Monat bietet eine gute Balance aus Wetter, Andrang und Preisen, mit einigen Abwagungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This month offers a decent balance of weather, crowds, and prices, with some trade-offs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes ofrece un equilibrio aceptable entre clima, afluencia y precios, con algunas concesiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mois offre un bon equilibre entre meteo, affluence et prix, avec quelques compromis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo mese offre un buon equilibrio tra meteo, folla e prezzi, con qualche compromesso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este mes oferece um bom equilibrio entre clima, movimento e precos, com alguns compromissos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот месяц даёт неплохой баланс погоды, цен и количества людей, хотя и с компромиссами."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deze maand biedt een redelijk evenwicht tussen het weer, de drukte en de prijzen, met enkele afwegingen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يوفر هذا الشهر توازنًا جيدًا بين الطقس، والزحام، والأسعار، مع بعض المقايضات."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "今月は、天気、人混み、価格のバランスがまずまずで、いくつかのトレードオフがあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "이번 달은 일부 타협이 있기는 하지만 날씨, 인파, 가격 면에서 적절한 균형을 제공합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "这个月份在天气、人群和价格之间提供了不错的平衡，但有一些取舍。"
          }
        }
      }
    },
    "country_detail.seasonality.footer": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einblicke zur Saisonalitat basieren auf historischen Klimadurchschnitten und typischen Reisemustern. Der Zeitpunkt kann sich von Jahr zu Jahr andern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seasonality insights are based on historical climate averages and typical travel patterns. Timing may vary year to year."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ideas de estacionalidad se basan en promedios climaticos historicos y patrones tipicos de viaje. El momento puede variar de un ano a otro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les indications de saisonnalite sont basees sur des moyennes climatiques historiques et des habitudes de voyage typiques. La periode peut varier d'une annee a l'autre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le indicazioni sulla stagionalita si basano su medie climatiche storiche e modelli di viaggio tipici. Il periodo puo variare di anno in anno."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os insights de sazonalidade se baseiam em medias climaticas historicas e padroes tipicos de viagem. O momento pode variar de ano para ano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сведения о сезонности основаны на исторических климатических средних и типичных туристических паттернах. Из года в год время может немного отличаться."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Inzichten over seizoensgebondenheid zijn gebaseerd op historische klimaatgemiddelden en typische reispatronen. De timing kan van jaar tot jaar variëren."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تستند رؤى الموسمية إلى متوسطات مناخية تاريخية وأنماط السفر المعتادة. قد يختلف التوقيت من عام لآخر."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "季節性に関する洞察は、過去の気候平均と一般的な旅行パターンに基づいています。時期は年ごとに異なる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "계절적 통찰은 과거 기후 평균과 일반적인 여행 패턴을 기반으로 합니다. 시기는 해마다 달라질 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "季节性洞察基于历史气候平均值和典型旅行模式。时间可能会因年份而有所不同。"
          }
        }
      }
    },
