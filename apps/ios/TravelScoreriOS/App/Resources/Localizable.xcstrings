    "Large Title — Discover the world": {},
    "legal.advisories.body": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sicherheitshinweise und Punktzahlen stammen aus offentlich zuganglichen Quellen und Daten Dritter. Bedingungen konnen sich schnell andern, und Travel Adventure Finder garantiert weder Genauigkeit noch Vollstandigkeit oder Aktualitat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Safety advisories and scores are derived from publicly available sources and third-party data. Conditions may change rapidly, and Travel Adventure Finder does not guarantee accuracy, completeness, or timeliness."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los avisos y puntajes de seguridad provienen de fuentes publicas y datos de terceros. Las condiciones pueden cambiar rapidamente y Travel Adventure Finder no garantiza exactitud, integridad ni actualidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les alertes de securite et les scores proviennent de sources publiques et de donnees tierces. Les conditions peuvent evoluer rapidement, et Travel Adventure Finder ne garantit ni l'exactitude, ni l'exhaustivite, ni l'actualite des informations."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli avvisi di sicurezza e i punteggi derivano da fonti pubbliche e dati di terze parti. Le condizioni possono cambiare rapidamente e Travel Adventure Finder non garantisce accuratezza, completezza o tempestivita."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avisos de seguranca e pontuacoes sao derivados de fontes publicas e dados de terceiros. As condicoes podem mudar rapidamente, e o Travel Adventure Finder nao garante precisao, completude ou atualidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рекомендации по безопасности и оценки основаны на общедоступных источниках и сторонних данных. Условия могут быстро меняться, и Travel Adventure Finder не гарантирует точность, полноту или актуальность информации."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Veiligheidsadviezen en scores zijn afgeleid van openbaar beschikbare bronnen en gegevens van derden. De omstandigheden kunnen snel veranderen, en Travel Adventure Finder garandeert geen juistheid, volledigheid of tijdigheid."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تستند الإرشادات المتعلقة بالسلامة والتقييمات إلى مصادر متاحة للجمهور وبيانات من طرف ثالث. قد تتغير الظروف بسرعة، ولا يضمن موقع مكتشف مغامرات السفر الدقة أو الاكتمال أو التوقيت المناسب."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "安全に関する注意情報やスコアは、公開されている情報源および第三者のデータに基づいて算出されています。状況は急速に変化する可能性があり、Travel Adventure Finderは正確性、完全性、または適時性を保証するものではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "안전 권고 및 점수는 공개적으로 이용 가능한 자료와 제3자 데이터를 기반으로 합니다. 상황은 급격히 변할 수 있으며, 트래블 어드벤처 파인더는 정확성, 완전성 또는 시의성을 보장하지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "安全建议和评分来源于公开可用的资料和第三方数据。情况可能会迅速变化，旅行探险发现者不保证其准确性、完整性或及时性。"
          }
        }
      }
    },
