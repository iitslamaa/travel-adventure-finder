          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ podem precisar de preparacao de visto para %@ %@. Melhor passaporte salvo para essa parada: %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ может понадобиться визовая подготовка для %@ %@. Лучший сохраненный паспорт для этой остановки: %@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ heeft mogelijk een visumvoorbereiding nodig voor %@ %@. Beste bewaarde paspoort voor die stop: %@."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "قد يحتاج %@ إلى تجهيز تأشيرة لـ %@ %@. أفضل جواز سفر محفوظ لتلك المحطة: %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ は %@ %@ のためにビザ準備が必要かもしれません。そのための最適なパスポートの保存先は %@ です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@는 %@ %@를 위해 비자 준비가 필요할 수 있습니다. 해당 목적지에 가장 적합한 여권: %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ 可能需要为 %@ %@ 准备签证。最适合在该站点使用的护照：%@。"
          }
        }
      }
    },
    "trip_planner.whos_going.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass es solo oder füg Freunde hinzu, um gemeinsame Bucket-List-Lander zu vergleichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep it solo or add friends to compare shared bucket-list countries."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenlo en solitario o agrega amigos para comparar paises compartidos de la lista de deseos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des amis ou gardez ce voyage en solo pour le moment."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienilo da solo oppure aggiungi amici per confrontare i paesi in comune nelle bucket list."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha solo ou adicione amigos para comparar paises compartilhados na lista de desejos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оставьте поездку сольной или добавьте друзей, чтобы сравнить общие страны из bucket list."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Houd het solo of voeg vrienden toe om gedeelde bucketlist-landen te vergelijken."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "احتفظ بها منفردًا أو أضف أصدقاء لمقارنة البلدان المدرجة في قائمة الأمنيات المشتركة."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ソロで続けるか、友達を追加して共有のバケットリストの国を比較しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "혼자 하거나 친구를 추가하여 공유 버킷리스트 국가를 비교하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "保持独自进行，或添加朋友以比较共享的愿望清单国家。"
          }
        }
      }
    },
