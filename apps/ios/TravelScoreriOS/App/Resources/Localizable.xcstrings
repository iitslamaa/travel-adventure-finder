          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот месяц даёт неплохой баланс погоды, цен и количества людей, хотя и с компромиссами."
          }
        }
      }
    },
    "country_detail.seasonality.footer": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einblicke zur Saisonalitat basieren auf historischen Klimadurchschnitten und typischen Reisemustern. Der Zeitpunkt kann sich von Jahr zu Jahr andern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seasonality insights are based on historical climate averages and typical travel patterns. Timing may vary year to year."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ideas de estacionalidad se basan en promedios climaticos historicos y patrones tipicos de viaje. El momento puede variar de un ano a otro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les indications de saisonnalite sont basees sur des moyennes climatiques historiques et des habitudes de voyage typiques. La periode peut varier d'une annee a l'autre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le indicazioni sulla stagionalita si basano su medie climatiche storiche e modelli di viaggio tipici. Il periodo puo variare di anno in anno."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os insights de sazonalidade se baseiam em medias climaticas historicas e padroes tipicos de viagem. O momento pode variar de ano para ano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сведения о сезонности основаны на исторических климатических средних и типичных туристических паттернах. Из года в год время может немного отличаться."
          }
        }
      }
    },
