    "trip_planner.stats.group_snapshot_summary_format": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld Reisende, %lld Lander, eine klarere Sicht darauf, wie die Reise Gesamtwert, Sicherheit, Saisonalitat und Logistik ausbalanciert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld travelers, %lld countries, one cleaner view of how the trip balances overall score, safety, seasonality, and logistics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld viajeros, %lld paises, una vista mas clara de como el viaje equilibra puntaje general, seguridad, estacionalidad y logistica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld voyageurs, %lld pays, une vue plus claire de l'equilibre entre score global, securite, saisonnalite et logistique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld viaggiatori, %lld paesi, una visione piu chiara di come il viaggio bilancia punteggio complessivo, sicurezza, stagionalita e logistica."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld viajantes, %lld paises, uma visao mais clara de como a viagem equilibra pontuacao geral, seguranca, sazonalidade e logistica."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld путешественников, %lld стран и более ясная картина того, как поездка балансирует общий балл, безопасность, сезонность и логистику."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%lld reizigers, %lld landen, één overzichtelijker beeld van hoe de reis de algemene score, veiligheid, seizoensgebondenheid en logistiek in balans brengt."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%lld مسافراً، %lld دولة، رؤية أكثر وضوحاً لكيفية توازن الرحلة بين التقييم العام، السلامة، الموسمية، واللوجستيات."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%lld 人の旅行者、%lld カ国、旅行が全体のスコア、安全性、季節性、そして物流のバランスをどのように取るかをより明確に示すビュー。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%lld명의 여행자, %lld개의 국가, 여행이 전체 점수, 안전, 계절성, 그리고 물류를 어떻게 균형 있게 보여주는지에 대한 더 깔끔한 시각."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%lld 名旅行者，%lld 个国家，一种更清晰的方式来查看旅行如何平衡整体评分、安全性、季节性和后勤。"
          }
        }
      }
    },
