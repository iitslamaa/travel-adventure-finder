    "trip_planner.countries.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalte die Route hier und offne die sortierte Landerliste, wenn du mehr hinzufugen willst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the route here, then open the ranked country list when you want to add more."
